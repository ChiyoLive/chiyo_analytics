# serializer version: 1
# name: test_gen_generates_expected_files[docker_compose]
  '''
  services:
    # =========================================================================
    # 1. PostgreSQL (元数据及配置存储)
    # =========================================================================
    cyanly-postgres:
      image: postgres:18-alpine
      container_name: cyanly-postgres
      ports:
      - 5432:5432
      environment:
        POSTGRES_DB: cyanly
        POSTGRES_USER: ${DB_USERNAME:-cyanly}
        POSTGRES_PASSWORD: ${DB_PASSWORD:-cyanly-password-change-me}
      volumes:
      - pg-data:/var/lib/postgresql
      healthcheck:
        # pg_isready 检查 PostgreSQL 数据库连接是否就绪
        test: ["CMD-SHELL", "pg_isready -U ${DB_USERNAME:-cyanly} -d cyanly"]
        interval: 2s
        timeout: 3s
        retries: 15
      restart: always
  
    # =========================================================================
    # 2. Redis (高并发写入缓存队列)
    # =========================================================================
    cyanly-redis:
      image: redis:8-alpine
      container_name: cyanly-redis
      command: ["redis-server", "--appendonly", "yes"]
      ports:
      - 6379:6379
      volumes:
      - redis-data:/data
      healthcheck:
        # 使用 redis-cli ping 检查 Redis 状态
        test: ["CMD", "redis-cli", "ping"]
        interval: 2s
        timeout: 3s
        retries: 10
      restart: always
  
    # =========================================================================
    # 3. ClickHouse (分析型列式数据库)
    # =========================================================================
    cyanly-clickhouse:
      image: clickhouse:lts
      container_name: cyanly-clickhouse
      ports:
      - 9000:9000
      - 8123:8123
      environment:
        CLICKHOUSE_DB: cyanly
        CLICKHOUSE_USER: ${CH_USERNAME:-default}
        CLICKHOUSE_PASSWORD: ${CH_PASSWORD:-cyanly-password-change-me}
        CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT: 1
      volumes:
      - clickhouse-data:/var/lib/clickhouse
      ulimits:
        nofile:
          soft: 262144
          hard: 262144
      healthcheck:
        # 通过 wget 检查 ClickHouse HTTP 接口的 /ping 状态（不需要密码）
        test: ["CMD-SHELL", "wget --spider -q http://localhost:8123/ping || exit 1"]
        interval: 2s
        timeout: 3s
        retries: 15
      restart: always
  
    # =========================================================================
    # 4. PostgreSQL 结构迁移 (在 PG 状态为 Healthy 时才执行)
    # =========================================================================
    cyanly-migrate-pg:
      image: ghcr.io/chiyolive/cyanly-backend:latest
      container_name: cyanly-migrate-pg
      command: ["cy_migrate", "--driver", "postgres", "--dsn", "postgres://${DB_USERNAME:-cyanly}:${DB_PASSWORD:-cyanly-password-change-me}@cyanly-postgres:5432/cyanly?sslmode=disable",
        "--migrations", "/app/migrations/pg_metadata", "apply"]
      depends_on:
        cyanly-postgres:
          condition: service_healthy
  
    # =========================================================================
    # 5. ClickHouse 结构迁移 (在 CH 状态为 Healthy 时才执行)
    # =========================================================================
    cyanly-migrate-ch:
      image: ghcr.io/chiyolive/cyanly-backend:latest
      container_name: cyanly-migrate-ch
      command: ["cy_migrate", "--driver", "clickhouse", "--dsn", "clickhouse://${CH_USERNAME:-default}:${CH_PASSWORD:-cyanly-password-change-me}@cyanly-clickhouse:9000/cyanly",
        "--migrations", "/app/migrations/ch_analytics", "--var", "table=cyanly.events",
        "apply"]
      depends_on:
        cyanly-clickhouse:
          condition: service_healthy
  
    # =========================================================================
    # 6. Go Collector (埋点收集服务)
    # =========================================================================
    cyanly-collector:
      image: ghcr.io/chiyolive/cyanly-backend:latest
      container_name: cyanly-collector
      command: ["collector", "-config", "/app/chiyo_analytics.toml"]
      ports:
      - "${COLLECTOR_PORT:-8080}:${COLLECTOR_PORT:-8080}"
      volumes:
      - ./chiyo_analytics.toml:/app/chiyo_analytics.toml
      - ./geoip:/app/geoip
      depends_on:
        cyanly-migrate-pg:
          condition: service_completed_successfully
        cyanly-redis:
          condition: service_healthy
      restart: always
  
    # =========================================================================
    # 7. Go Worker (日志处理守护进程)
    # =========================================================================
    cyanly-worker:
      image: ghcr.io/chiyolive/cyanly-backend:latest
      container_name: cyanly-worker
      command: ["worker", "-config", "/app/chiyo_analytics.toml"]
      ports:
      - "${WORKER_PORT:-8082}:${WORKER_PORT:-8082}"
      volumes:
      - ./chiyo_analytics.toml:/app/chiyo_analytics.toml
      - ./geoip:/app/geoip
      depends_on:
        cyanly-migrate-ch:
          condition: service_completed_successfully
        cyanly-redis:
          condition: service_healthy
      restart: always
  
    # =========================================================================
    # 8. GeoIP Updater (GeoIP 定期自动更新)
    # =========================================================================
    cyanly-updater:
      image: ghcr.io/chiyolive/cyanly-backend:latest
      container_name: cyanly-updater
      command: ["updater", "-config", "/app/chiyo_analytics.toml"]
      volumes:
      - ./chiyo_analytics.toml:/app/chiyo_analytics.toml
      - ./geoip:/app/geoip
      depends_on:
      - cyanly-worker
      restart: always
  
    # =========================================================================
    # 9. Go Query API (分析查询服务)
    # =========================================================================
    cyanly-api:
      image: ghcr.io/chiyolive/cyanly-backend:latest
      container_name: cyanly-api
      command: ["api", "-config", "/app/chiyo_analytics.toml"]
      ports:
      - "${API_PORT:-8081}:${API_PORT:-8081}"
      volumes:
      - ./chiyo_analytics.toml:/app/chiyo_analytics.toml
      depends_on:
        cyanly-migrate-pg:
          condition: service_completed_successfully
        cyanly-migrate-ch:
          condition: service_completed_successfully
      restart: always
  
    # =========================================================================
    # 10. Dashboard (数据可视化面板)
    # =========================================================================
    cyanly-dashboard:
      image: ghcr.io/chiyolive/cyanly-dashboard:latest
      container_name: cyanly-dashboard
      ports:
      - "${DASHBOARD_PORT:-8079}:${DASHBOARD_PORT:-8079}"
      environment:
      - ANALYTICS_API_URL=${ANALYTICS_API_URL:-http://localhost:8081}
      depends_on:
      - cyanly-api
      restart: always
  
  volumes:
    pg-data: {}
    clickhouse-data: {}
    redis-data: {}
  
  '''
# ---
# name: test_gen_generates_expected_files[env]
  '''
  DB_USERNAME=cyanly
  DB_PASSWORD=cyanly-password-change-me
  CH_USERNAME=default
  CH_PASSWORD=cyanly-password-change-me
  ANALYTICS_API_URL=http://localhost:8081
  COLLECTOR_PORT=8080
  API_PORT=8081
  WORKER_PORT=8082
  DASHBOARD_PORT=8079
  
  '''
# ---
